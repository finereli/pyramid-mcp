{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pyramid-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2025-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },

  // Custom domain — wrangler provisions DNS + cert for this on the finereli.com zone.
  "routes": [
    { "pattern": "pyramid.finereli.com", "custom_domain": true }
  ],

  // One Durable Object per authenticated principal. The MCP agent's own SQLite
  // storage IS the per-user memory store (models, observations, tags, summaries,
  // embedding blobs). Keyed by Google OAuth `sub`.
  "durable_objects": {
    "bindings": [
      { "name": "MEMORY_DO", "class_name": "MemoryDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["MemoryDO"] }
  ],

  // OAuth token/grant store (required by @cloudflare/workers-oauth-provider).
  // Create with: wrangler kv namespace create OAUTH_KV → paste the id here.
  "kv_namespaces": [
    { "binding": "OAUTH_KV", "id": "e03653aa5a5a405b962874c375879174" }
  ]

  // Secrets (set via `wrangler secret put`; never commit):
  //   GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET — Google OAuth client
  // Local dev (.dev.vars, gitignored): DEV_AUTH=true + OPENAI_API_KEY
  // See SETUP.md.
}
